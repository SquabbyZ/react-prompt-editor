## 📁 项目结构

```
src/
├── components/                # 组件目录
│   ├── PromptEditor/         # 主编辑器组件
│   │   ├── index.tsx         # 入口文件
│   │   ├── Node.tsx          # 节点组件（核心）
│   │   ├── PromptEditor.types.ts  # 类型定义
│   │   └── styles.css        # 样式文件
│   ├── AIOptimizeModal/      # AI 优化弹窗
│   │   └── AIOptimizeModal.tsx
│   ├── CodeMirrorEditor/     # Markdown 编辑器封装
│   │   ├── index.tsx
│   │   └── CodeMirrorEditor.types.ts
│   └── TreeNode/             # 树节点组件（备用）
│       ├── index.tsx
│       └── TreeNode.types.ts
├── stores/                    # Zustand 状态管理
│   ├── index.ts              # 导出
│   ├── editorStore.ts        # 编辑器状态（树形数据）
│   └── optimizeStore.ts      # AI 优化状态（消息流）
├── hooks/                     # 自定义 Hooks
│   └── useTreeState.ts       # 树状态管理（已迁移到 store）
├── utils/                     # 工具函数
│   └── tree-utils.ts         # 树形数据转换
├── types/                     # TypeScript 类型
│   └── index.ts              # 所有类型定义
├── styles/                    # 样式文件
│   ├── variables.css         # CSS 变量（主题色板）
│   ├── themes/default.css    # 默认主题
│   └── tailwind.css          # Tailwind 配置
├── index.ts                   # 库入口（导出公共 API）
└── App.tsx                    # 开发环境演示
```

