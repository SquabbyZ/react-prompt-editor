## 📝 编码规范

### TypeScript 规范

```typescript
// ✅ 使用 interface 定义公开 API
export interface PromptEditorProps {
  initialValue?: TaskNode[];
  onChange?: (data: TaskNode[]) => void;
}

// ✅ 使用 type 定义联合类型
type Theme = 'default' | 'ant-design';

// ✅ 明确的返回类型
const handleAddChild = (parentId: string): string => {
  return newNodeId;
};

// ❌ 避免 any
const data: any = {};  // 不好
const data: TaskNode = {};  // 好
```

### React 规范

```typescript
// ✅ 使用 useCallback 缓存事件处理函数
const handleClick = useCallback(() => {
  // ...
}, [deps]);

// ✅ 使用 useMemo 缓存计算结果
const tree = useMemo(() => {
  return mapToArray(store);
}, [store]);

// ✅ 使用 useRef 存储不需要触发重渲染的值
const storeRef = useRef<EditorStoreType | null>(null);

// ❌ 避免在 render 中创建新对象
<Component config={{ a: 1 }} />  // 每次渲染都创建新对象
const config = useMemo(() => ({ a: 1 }), []);
<Component config={config} />
```

### Zustand 规范

```typescript
// ✅ 订阅最小化状态
const storeMap = store((state) => state.store);  // 只订阅 store

// ✅ 使用 getState 获取最新值（避免闭包陷阱）
const node = store.getState().getNode(nodeId);

// ❌ 避免订阅整个 store
const state = store((state) => state);  // 任何变化都会触发重渲染

// ❌ 避免在 useEffect 中使用过时的闭包
useEffect(() => {
  const oldNode = node;  // 可能是旧值
}, [node]);
```

### CSS/Tailwind 规范

```typescript
// ✅ 使用 Tailwind 类名
<div className="flex items-center gap-2 rounded-lg bg-indigo-50 px-4 py-2">

// ✅ 使用 CSS 变量（主题化）
<div style={{ color: 'var(--pe-color-primary)' }}>

// ❌ 避免内联样式
<div style={{ color: '#6366f1', padding: '16px' }}>

// ❌ 避免硬编码颜色
className="text-purple-500"  // 不统一
className="text-indigo-500"  // 统一使用 Indigo
```

### 命名规范

```typescript
// 组件：PascalCase
const PromptEditor = () => {};

// 函数/变量：camelCase
const handleNodeRun = () => {};
const expandedNodes = new Set();

// 常量：UPPER_SNAKE_CASE
const MAX_DEPTH = 10;

// 类型/接口：PascalCase
interface TaskNode {}
type NodeStore = Map<string, TaskNodeMinimal>;

// 文件名：kebab-case 或 PascalCase（组件）
prompt-editor.types.ts
PromptEditor.tsx
```

