{
  "name": "react-prompt-editor",
  "version": "1.0.4",
  "description": "A powerful tree-structured prompt editor for complex AI workflows, featuring Markdown editing, AI optimization with streaming responses, dependency management, and node execution tracking.",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/lib/index.js"
    },
    "./dist/*": "./dist/*",
    "./styles/index.css": "./dist/styles/index.css"
  },
  "main": "dist/lib/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "style": "dist/styles/index.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "father build && node scripts/build-css.js",
    "build:css": "node scripts/build-css.js",
    "build:prod": "father build && node scripts/build-css.js && node scripts/remove-console.js && node scripts/compress-js.js",
    "build:watch": "father dev",
    "build:analyze": "pnpm build && node scripts/analyze-bundle.js",
    "build:prod:analyze": "node scripts/analyze-prod-bundle.js",
    "analyze:deps": "node scripts/analyze-dependency-impact.js",
    "clean-cache": "rm -rf .dumi/tmp",
    "dev": "dumi dev",
    "docs:build": "dumi build",
    "docs:preview": "dumi preview",
    "doctor": "father doctor",
    "lint": "npm run lint:es && npm run lint:css",
    "lint:css": "stylelint \"{src,test}/**/*.{css,less}\"",
    "lint:css:fix": "stylelint \"{src,test}/**/*.{css,less}\" --fix",
    "lint:es": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\"",
    "lint:es:fix": "eslint \"{src,test}/**/*.{js,jsx,ts,tsx}\" --fix",
    "lint:fix": "npm run lint:es:fix && npm run lint:css:fix",
    "prepare": "husky install && dumi setup",
    "prepublishOnly": "father doctor && npm run build",
    "start": "npm run dev",
    "test": "vitest run",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test e2e/basic-flow.spec.ts",
    "publish:package": "bash scripts/publish.sh",
    "publish:beta": "bash scripts/publish.sh beta",
    "publish:alpha": "bash scripts/publish.sh alpha"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{md,json}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{css,less}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --parser=typescript --write"
    ]
  },
  "dependencies": {
    "codemirror": "5.65.20",
    "react-codemirror2": "7.3.0",
    "clsx": "^2.1.1",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.7.0",
    "markdown-it": "^14.1.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-highlightjs": "^4.3.0",
    "markdown-it-task-lists": "^2.1.1",
    "react-window": "^2.2.7",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^17.1.2",
    "@commitlint/config-conventional": "^17.1.0",
    "@midscene/web": "^1.7.3",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-container": "^4.0.0",
    "@types/markdown-it-emoji": "^3.0.1",
    "@types/markdown-it-footnote": "^3.0.4",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@umijs/lint": "^4.0.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "dotenv": "^17.4.2",
    "dumi": "2.4.21",
    "eslint": "^8.23.0",
    "father": "^4.1.0",
    "husky": "^8.0.1",
    "jsdom": "^29.0.2",
    "lint-staged": "^13.0.3",
    "postcss": "^8.5.8",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^3.0.0",
    "prettier-plugin-packagejson": "^2.2.18",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "stylelint": "^14.9.1",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "terser": "^5.46.1",
    "vitest": "^0.34.6"
  },
  "peerDependencies": {
    "@ant-design/x": "^2.0.0",
    "antd": "^5.0.0",
    "react": ">=16.9.0",
    "react-dom": ">=16.9.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SquabbyZ/react-prompt-editor.git",
    "branch": "master"
  },
  "homepage": "https://github.com/SquabbyZ/react-prompt-editor#readme",
  "bugs": {
    "url": "https://github.com/SquabbyZ/react-prompt-editor/issues"
  },
  "keywords": [
    "react",
    "prompt",
    "editor",
    "markdown",
    "ai",
    "tree",
    "codemirror",
    "antd"
  ],
  "authors": [
    "601709253@qq.com"
  ]
}